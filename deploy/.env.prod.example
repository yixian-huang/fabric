# 生产 fabricoption.com（复制为 deploy/.env.prod，勿提交）

# SSH：直连不稳定时用跳板
PROD_SSH_HOST=23.146.4.16
PROD_SSH_PORT=52322
PROD_SSH_USER=root
PROD_SSH_KEY=.ssh

# 服务器上的路径（在目标机执行时无需 SSH 变量）
PROD_SITE_ROOT=/opt/1panel/apps/openresty/openresty/www/sites/fabricoption.com
PROD_WEB_DIST=/opt/1panel/apps/openresty/openresty/www/sites/fabricoption.com/index/dist
PROD_DEPLOY_DIR=/opt/fabric-go
PROD_API_PORT=8081

# 构建 todo-web 时使用
VITE_API_BASE_URL=https://fabricoption.com/api
VITE_SITE_URL=https://fabricoption.com
VITE_FABRIC_THEME=modern

# API 升级（--api 时使用）
IMAGE_API=ghcr.io/yixian-huang/fabric-api:latest
