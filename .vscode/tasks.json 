{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Django via uv (debugpy)",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m", "debugpy",
        "--listen", "127.0.0.1:5678",
        "--wait-for-client",
        "${workspaceFolder}/todo-server/manage.py",
        "runserver",
        "0.0.0.0:8000"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}