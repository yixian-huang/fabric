# Fabric 自托管一键部署 — 复制为 .env 后修改
# cp .env.example .env

# 对外 HTTP 端口（NAS / 本机访问 http://<host>:HTTP_PORT）
HTTP_PORT=8088

# 图片存储：embedded-minio（内置 MinIO）| local（本机磁盘）
STORAGE_MODE=embedded-minio

# PostgreSQL
POSTGRES_DB=fabric
POSTGRES_USER=fabric
POSTGRES_PASSWORD=change-me-postgres

# MinIO（对象存储，附件/图片）
MINIO_ROOT_USER=fabric
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=fabric

# API 鉴权（install.sh 可自动生成）
JWT_SECRET=change-me-jwt-secret

# 首次安装默认管理员（install.sh 可自动生成密码）
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin
